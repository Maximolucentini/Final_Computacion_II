# LogStream Analytics - Variables de entorno (ejemplo)
# Copiá este archivo a .env y ajustá los valores

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30

# --- Base de datos SQLite ---
DB_PATH=data/logstream.db
DB_LOCK_TIMEOUT=10
DB_LOCK_BLOCKING_TIMEOUT=15

# --- Log Server (ingesta) ---
LOG_SERVER_HOST=::
LOG_SERVER_PORT=9000

# --- Query Engine ---
QUERY_ENGINE_HOST=::
QUERY_ENGINE_PORT=9001

# --- Log Producer (cliente) ---
PRODUCER_DEFAULT_HOST=127.0.0.1
PRODUCER_DEFAULT_PORT=9000
PRODUCER_DEFAULT_RATE=5
PRODUCER_DEFAULT_ERROR_RATE=0.05
PRODUCER_DEFAULT_ANOMALY_RATE=0.01

# --- Workers Celery ---
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_RESULT_EXPIRES=3600
CELERY_TIMEZONE=America/Argentina/Mendoza

# --- Alert Manager ---
FIFO_PATH=data/alert_pipe
ALERT_LEVELS=ERROR,CRITICAL

# --- Logging general ---
LOG_LEVEL=INFO
